{
  "meta": {
    "version": "1.1",
    "methodology": "INFORM Risk Index (UN/JRC) — Hazard & Exposure, Vulnerability, Lack of Coping Capacity, each 0–10. Static structural baseline, refreshed annually (not a live feed).",
    "use": "Structural modifier M on the live behavioral signal. Same raw signal is AMPLIFIED in a fragile/low-coping country, DAMPED in a resilient one. Also powers the country-card baseline when no live events exist (so the card is never empty).",
    "formula": "F = clamp((vulnerability*coping)/100,0,1); M = clamp(0.70 + F*1.6, 0.70, 1.60); behavioralEff = min(5, behavioral*M)",
    "coverage": "~70 countries: full G20 + all INFORM very-high/high-risk states + major travel destinations. Long tail falls back to M=1.0 (neutral) + graceful 'no active threats' card — never breaks.",
    "source": "INFORM 2024 (approx, public bands). For full ~191-country coverage, ingest the official INFORM dataset (annual CSV).",
    "fields": "hazard, vulnerability, coping (= lack of coping capacity; higher = worse)"
  },
