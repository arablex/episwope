{
  "meta": {
    "version": "1.0",
    "methodology": "Macroeconomic risk indicators with FLOW discipline — we track rate-of-change, not stock levels (Meadows). Chronic weakness is background; recent moves are signal.",
    "use": "Small additive component to Risk Score + explainability layer in country card. NOT a predictive boost: macro indicators are LAGGING (they confirm crisis, they don't lead it). Value: explainability ('why this score') over forecasting power.",
    "source": "Curated seed (2024–2025 approx, from IMF/World Bank/central banks). Replaceable by scripts/macro_signals.py once wired to GitHub Actions (monthly refresh).",
    "fields": {
      "gdp_yoy_pct":       "latest year-over-year GDP growth (negative = contraction, signal)",
      "gdp_3yr_avg_pct":   "rolling 3-year average — baseline",
      "unemp_pct":         "current unemployment rate",
      "unemp_2yr_delta_pp": "change in unemployment over 2 years in percentage points",
      "debt_to_gdp_pct":   "general government debt / GDP",
      "debt_5yr_delta_pp": "change in debt/GDP over 5 years in percentage points (rapid rise = fiscal stress)",
      "policy_rate_pct":   "central bank key rate (high or rapidly rising = monetary stress)"
    }
  },
